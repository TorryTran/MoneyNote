<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <LinearLayout
        android:id="@+id/listContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/notes_title"
            android:textColor="@color/accent_blue"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/notes_hint"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvEmptyNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/notes_empty_state"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNotes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/editorContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBackToList"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/notes_editor_title"
                android:textColor="@color/accent_blue"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSaveNote"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_btn_primary"
                android:minWidth="80dp"
                android:text="@string/action_save"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/etNoteTitle"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_dark"
            android:hint="@string/notes_title_hint"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNoteContent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_rounded_card"
            android:gravity="top|start"
            android:hint="@string/notes_placeholder"
            android:inputType="textMultiLine|textCapSentences"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnBold"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_dark"
                    android:text="B"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnItalic"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_dark"
                    android:text="I"
                    android:textColor="@color/text_primary"
                    android:textStyle="italic" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnUnderline"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_dark"
                    android:text="U"
                    android:textColor="@color/text_primary" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnStrike"
                    android:layout_width="48dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_dark"
                    android:text="S"
                    android:textColor="@color/text_primary" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnTextLarger"
                    android:layout_width="56dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_dark"
                    android:text="A+"
                    android:textColor="@color/text_primary" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <Button
                    android:id="@+id/btnTextSmaller"
                    android:layout_width="56dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_input_dark"
                    android:text="A-"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="@string/notes_add"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/accent_blue"
        app:tint="@color/white" />

</FrameLayout>
